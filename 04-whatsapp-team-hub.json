            { "fieldLabel": "Why do you want it? (optional)", "fieldType": "textarea" },
            {
              "fieldLabel": "How urgent?",
              "fieldType": "dropdown",
              "fieldOptions": {
                "values": [
                  { "option": "🟢 Whenever free" },
                  { "option": "🟡 This week" },
                  { "option": "🔴 ASAP" }
                ]
              }
            }
          ]
        },
        "options": {
          "customCss": "body{background:linear-gradient(135deg,#e8f5e9,#c8e6c9);font-family:Georgia,serif;} .form-container{background:#fff;border:2px solid #66bb6a;border-radius:16px;} h1{color:#2e7d32;} button{background:#43a047 !important;border-radius:999px !important;}"
        }
      },
      "id": "request-form",
      "name": "📋 Book Request Form",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2.1,
      "position": [220, 280],
      "webhookId": "bibliophile-request"
    },

    {
      "parameters": {
        "operation": "search",
        "base": { "__rl": true, "value": "={{ $vars.AIRTABLE_BASE_ID }}", "mode": "id" },
        "table": { "__rl": true, "value": "Books", "mode": "name" },
        "filterByFormula": "=SEARCH(LOWER(\"{{ $json['Book Title You Want'] }}\"), LOWER({Title}))",
        "options": { "limit": 1 }
      },
      "id": "check-availability",
      "name": "🔎 Check If Book Available",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [460, 280]
    },

    {
      "parameters": {
        "jsCode": "const requestor = $('📋 Book Request Form').item.json['Your Name'];\nconst bookWanted = $('📋 Book Request Form').item.json['Book Title You Want'];\nconst reason = $('📋 Book Request Form').item.json['Why do you want it? (optional)'] || 'No reason given';\nconst urgency = $('📋 Book Request Form').item.json['How urgent?'];\nconst found = $input.all();\n\nlet status = '❓ Not in library yet';\nlet foundTitle = bookWanted;\nif (found.length > 0) {\n  const s = found[0].json.fields?.Status || 'Unknown';\n  foundTitle = found[0].json.fields?.Title || bookWanted;\n  status = s === 'Available' ? '✅ AVAILABLE NOW' : s === 'Issued' ? `📕 Currently lent out` : `📌 ${s}`;\n}\n\nconst msg = `📚 *Book Request*\\n\\n👤 *From:* ${requestor}\\n📖 *Book:* ${foundTitle}\\n📊 *Status:* ${status}\\n⚡ *Urgency:* ${urgency}\\n💬 *Reason:* ${reason}`;\n\nreturn [{ json: { message: msg, requestor, bookWanted: foundTitle, status, urgency } }];"
      },
      "id": "build-request-msg",
      "name": "📝 Build Request Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 280]
    },

    {
      "parameters": {
        "url": "=https://graph.facebook.com/v18.0/{{ $vars.WHATSAPP_PHONE_NUMBER_ID }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $vars.WHATSAPP_ACCESS_TOKEN }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $vars.MEMBER1_PHONE }}\",\n  \"type\": \"text\",\n  \"text\": { \"body\": \"{{ $json.message }}\" }\n}",
        "options": {}
      },
      "id": "wa-member1-request",
      "name": "📱 WhatsApp → Member 1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [940, 160]
