      "id": "check-availability",
      "name": "🔎 Check If Book Available",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [460, 280]
    },
    {
      "parameters": {
        "jsCode": "const requestor = $('📋 Book Request Form').item.json['Your Name'];\nconst bookWanted = $('📋 Book Request Form').item.json['Book Title You Want'];\nconst reason = $('📋 Book Request Form').item.json['Why do you want it? (optional)'] || 'No reason given';\nconst urgency = $('📋 Book Request Form').item.json['How urgent?'] || '🟢 Whenever free';\nconst found = $input.all();\nlet status = '❓ Not in library yet';\nlet foundTitle = bookWanted;\nif (found.length > 0 && found[0].json.fields) {\n  const s = found[0].json.fields.Status || 'Unknown';\n  foundTitle = found[0].json.fields.Title || bookWanted;\n  if (s === 'Available') status = '✅ AVAILABLE NOW';\n  else if (s === 'Issued') status = `📕 Currently lent out (due ${found[0].json.fields['Due Date'] || '?'})`;\n  else status = `📌 ${s}`;\n}\nconst msg = `📚 *Book Request — Bibliophile Concierge*\\n\\n👤 *From:* ${requestor}\\n📖 *Book:* ${foundTitle}\\n📊 *Status:* ${status}\\n⚡ *Urgency:* ${urgency}\\n💬 *Reason:* ${reason}\\n\\n🌷 _Respond on WhatsApp to confirm!_`;\nreturn [{ json: { message: msg, requestor, bookWanted: foundTitle, status, urgency } }];"
      },
