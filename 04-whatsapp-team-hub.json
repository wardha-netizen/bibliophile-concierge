      "id": "all-books",
      "name": "📊 Get All Books",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [460, 780]
    },

    {
      "parameters": {
        "jsCode": "const books = $input.all().map(i => i.json.fields);\nconst total = books.length;\nconst available = books.filter(b => b.Status === 'Available').length;\nconst issued = books.filter(b => b.Status === 'Issued').length;\nconst completed = books.filter(b => b.Status === 'Completed').length;\nconst overdue = books.filter(b => {\n  if (b.Status !== 'Issued' || !b['Due Date']) return false;\n  return new Date(b['Due Date']) < new Date();\n}).length;\n\nconst issuedList = books\n  .filter(b => b.Status === 'Issued')\n  .map(b => `  • _${b.Title}_ → ${b['Lent To'] || 'unknown'} (due ${b['Due Date'] || '?'})`)\n  .join('\\n') || '  None';\n\nconst today = new Date().toLocaleDateString('en-GB', { weekday:'long', day:'numeric', month:'long' });\n\nconst msg = `🌿 *Bibliophile Team Digest*\\n📅 ${today}\\n\\n📚 *Library Stats:*\\n✅ Available: ${available}\\n📕 Issued: ${issued}\\n🏁 Completed: ${completed}\\n⚠️ Overdue: ${overdue}\\n📖 Total: ${total}\\n\\n📕 *Currently Out:*\\n${issuedList}\\n\\n_Happy reading, team! 🌷_`;\n\nreturn [{ json: { digestMsg: msg, overdue } }];"
      },
      "id": "build-digest",
      "name": "📊 Build Team Digest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 780]
    },

