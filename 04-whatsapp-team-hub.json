    {
      "parameters": {
        "jsCode": "const books = $input.all().map(i => i.json.fields);\nconst total = books.length;\nconst available = books.filter(b => b.Status === 'Available').length;\nconst issued = books.filter(b => b.Status === 'Issued').length;\nconst completed = books.filter(b => b.Status === 'Completed').length;\nconst overdue = books.filter(b => b.Status === 'Issued' && b['Due Date'] && new Date(b['Due Date']) < new Date()).length;\nconst issuedList = books.filter(b => b.Status === 'Issued').map(b => `  • _${b.Title}_ → ${b['Lent To'] || 'unknown'} (due ${b['Due Date'] || '?'})`).join('\\n') || '  None currently out';\nconst today = new Date().toLocaleDateString('en-GB', { weekday:'long', day:'numeric', month:'long' });\nconst msg = `🌿 *Bibliophile Team Digest*\\n📅 ${today}\\n\\n📚 *Library Stats:*\\n✅ Available: ${available}\\n📕 Issued: ${issued}\\n🏁 Completed: ${completed}\\n⚠️ Overdue: ${overdue}\\n📖 Total Books: ${total}\\n\\n📕 *Currently Out:*\\n${issuedList}\\n\\n_Happy reading, team! 🌷_`;\nreturn [{ json: { digestMsg: msg } }];"
      },
